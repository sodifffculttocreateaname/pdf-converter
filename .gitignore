# ============================================================
# Python 项目 .gitignore
# PDF工具箱 - GitHub上传配置
# ============================================================

# -------------------- Python 字节码缓存 --------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# -------------------- PyInstaller 构建产物 --------------------
# 构建目录（中间文件）
build/
# 分发目录（可执行文件，体积很大，约418MB）
dist/

# -------------------- 日志文件（运行时生成） --------------------
logs/
*.log

# -------------------- 虚拟环境 --------------------
venv/
env/
ENV/
.venv/

# -------------------- IDE 和编辑器配置 --------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# -------------------- Windows 系统文件 --------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -------------------- macOS 系统文件 --------------------
.DS_Store
.AppleDouble
.LSOverride

# -------------------- 测试生成的临时文件 --------------------
*.tmp
*.temp
.pytest_cache/
.coverage
htmlcov/

# -------------------- 外部工具目录 --------------------
# Poppler等第三方工具（用户自行下载）
tools/

# -------------------- 测试文件 --------------------
*.xlsx
*.pdf
*.pptx
*.docx
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.txt
!requirements.txt
!setup.iss
